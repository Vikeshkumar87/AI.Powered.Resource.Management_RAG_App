# Application Settings
APP_NAME=AI Resource Management RAG App
APP_VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite:///./resource_management.db

# Vector Store
