# Application Settings
APP_NAME=AI Resource Management RAG App
APP_VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite:///./resource_management.db

# Vector Store
CHROMA_PERSIST_DIR=./chroma_db
COLLECTION_NAME=resource_management

# LLM Configuration
# Set to "openai", "ollama", or "demo"
LLM_PROVIDER=ollama
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Embedding Model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080", "http://127.0.0.1:8080", "http://localhost:5173", "http://127.0.0.1:5173"]

# Logging
LOG_LEVEL=INFO
